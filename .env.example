# ============ Render (API) ============
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
PORT=3000
# Comma-separated: Vercel preview + production origins
CORS_ORIGIN=https://your-app.vercel.app,http://localhost:5173
# Public URL of the Vite app (Stripe success/cancel redirects)
WEB_APP_URL=https://your-app.vercel.app
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ============ Vercel (Web) ============
# Project Settings → Environment Variables
VITE_API_BASE_URL=https://your-api.onrender.com
# No trailing slash; enables absolute og:url, canonical, and social preview image URLs in index.html
VITE_SITE_ORIGIN=https://your-app.vercel.app
# Only for internal staging: show mock checkout in production build (never on public prod).
# VITE_ENABLE_MOCK_CHECKOUT=true
